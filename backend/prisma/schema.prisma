// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client"
  output        = "../generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
   directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id         Int      @id @default(autoincrement())
  nama       String
  email      String   @unique
  password   String
  role       Role     @default(USER)

  // Profile fields
  foto       String?
  no_hp      String?
  alamat     String?
  kota       String?
  provinsi   String?
  kode_pos   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pesanan    Pesanan[]
  testimoni  Testimoni[]
}

enum JenisKategori {
  RUNNING
  FUTSAL
  CASUAL
  FORMAL
  SANDAL
}

model Produk {
  id            Int      @id @default(autoincrement())
  kategori      JenisKategori
  nama_produk   String
  deskripsi     String
  harga         Decimal
  gambar        String          // gambar utama/thumbnail
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  detailPesanan  DetailPesanan[]
  varian         ProdukVarian[]  // baru
  testimoni      Testimoni[]

  // catatan: field `stok` lama dihapus, dipindah ke ProdukVarian
}

model ProdukVarian {
  id          Int      @id @default(autoincrement())
  produk_id   Int
  warna       String
  ukuran      String
  stok        Int      @default(0)
  gambar      String?

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  produk      Produk   @relation(fields: [produk_id], references: [id], onDelete: Cascade)

  @@unique([produk_id, warna, ukuran]) // cegah duplikat kombinasi
}

enum StatusPesanan {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Pesanan {
  id                 Int      @id @default(autoincrement())

  user_id            Int

  kode_pesanan       String   @unique

  nama_penerima      String
  email              String?
  no_hp              String

  alamat             String
  kota               String
  provinsi           String
  kode_pos           String
  catatan            String?

  total_harga        Decimal

  metode_pembayaran  String

  status             StatusPesanan @default(PENDING) // Ubah dari String ke enum

  tanggal_pesanan    DateTime @default(now())

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  user               User @relation(fields: [user_id], references: [id])
  

  detailPesanan      DetailPesanan[]
  testimoni          Testimoni[]
}

model DetailPesanan {
  id           Int @id @default(autoincrement())

  pesanan_id   Int
  produk_id    Int

  jumlah       Int
  harga        Decimal
  subtotal     Decimal
  warna        String?
  ukuran       String?

  pesanan      Pesanan @relation(fields: [pesanan_id], references: [id])
  produk       Produk  @relation(fields: [produk_id], references: [id])
}

model Testimoni {
  id            Int      @id @default(autoincrement())

  pesanan_id    Int
  user_id       Int
  produk_id     Int

  nama          String
  rating        Int
  komentar      String
  gambar        String?
  balasan       String?

  created_at    DateTime @default(now())

  pesanan       Pesanan @relation(fields: [pesanan_id], references: [id])
  user          User    @relation(fields: [user_id], references: [id])
  produk        Produk  @relation(fields: [produk_id], references: [id])

  @@unique([user_id, produk_id, pesanan_id])
}

model Notifikasi {
  id            Int      @id @default(autoincrement())
  judul         String
  pesan         String
  is_read       Boolean  @default(false)
  type          String   @default("REVIEW")
  reference_id  Int?
  created_at    DateTime @default(now())
}